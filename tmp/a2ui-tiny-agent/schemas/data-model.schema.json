{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tiny Agent UI Data Model",
  "type": "object",
  "required": ["agent", "sessions", "activeSessionId", "messages", "composer", "workflows", "toolActivity", "latestResult"],
  "properties": {
    "agent": {
      "type": "object",
      "properties": {
        "status": { "type": "string" },
        "model": { "type": "string" }
      }
    },
    "sessions": { "type": "array" },
    "activeSessionId": { "type": "string" },
    "messages": { "type": "array" },
    "composer": {
      "type": "object",
      "properties": {
        "value": { "type": "string" }
      }
    },
    "workflows": { "type": "array" },
    "toolActivity": { "type": "array" },
    "latestResult": { "type": "object" }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tiny Agent UI Events",
  "type": "object",
  "required": ["event", "payload"],
  "properties": {
    "event": {
      "type": "string",
      "enum": [
        "agent.message.send",
        "agent.workflow.start",
        "agent.session.select"
      ]
    },
    "payload": {
      "type": "object"
    }
  }
}

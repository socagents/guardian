{
  "id": "base-agent-ui.v0.1",
  "name": "Base Agent UI Catalog",
  "version": "0.1.0",
  "description": "A tiny trusted component catalog for agentic UIs.",
  "components": {
    "AgentShell": {
      "description": "Top-level application shell.",
      "required": ["title", "main"],
      "props": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "statusPath": { "type": "string" },
        "sidebar": { "type": "componentId" },
        "main": { "type": "componentId" },
        "aside": { "type": "componentId" }
      }
    },
    "Panel": {
      "description": "Framed content panel.",
      "required": ["title", "child"],
      "props": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "child": { "type": "componentId" }
      }
    },
    "Stack": {
      "description": "Vertical stack container.",
      "required": ["children"],
      "props": {
        "children": { "type": "componentIdList" },
        "gap": { "type": "string", "enum": ["sm", "md", "lg"] }
      }
    },
    "SessionList": {
      "description": "List of agent sessions.",
      "required": ["itemsPath"],
      "props": {
        "itemsPath": { "type": "string" },
        "activePath": { "type": "string" },
        "selectEvent": { "type": "eventName" }
      }
    },
    "ChatSurface": {
      "description": "Conversation area with messages and composer.",
      "required": ["messages", "composer"],
      "props": {
        "messages": { "type": "componentId" },
        "composer": { "type": "componentId" }
      }
    },
    "MessageList": {
      "description": "Bound list of chat messages.",
      "required": ["itemsPath"],
      "props": {
        "itemsPath": { "type": "string" }
      }
    },
    "PromptComposer": {
      "description": "Prompt input and submit action.",
      "required": ["valuePath", "submitEvent"],
      "props": {
        "valuePath": { "type": "string" },
        "placeholder": { "type": "string" },
        "submitLabel": { "type": "string" },
        "submitEvent": { "type": "eventName" }
      }
    },
    "WorkflowLauncher": {
      "description": "Buttons for guided agent workflows.",
      "required": ["itemsPath", "runEvent"],
      "props": {
        "itemsPath": { "type": "string" },
        "runEvent": { "type": "eventName" }
      }
    },
    "ToolActivity": {
      "description": "Recent tool/model activity.",
      "required": ["itemsPath"],
      "props": {
        "itemsPath": { "type": "string" }
      }
    },
    "ResultViewer": {
      "description": "Shows latest workflow or tool result.",
      "required": ["resultPath"],
      "props": {
        "resultPath": { "type": "string" }
      }
    }
  },
  "events": {
    "agent.message.send": {
      "description": "Send a user prompt to the agent backend.",
      "payloadSchema": {
        "type": "object",
        "properties": {
          "text": { "type": "string" }
        },
        "required": ["text"]
      }
    },
    "agent.workflow.start": {
      "description": "Start a named guided workflow.",
      "payloadSchema": {
        "type": "object",
        "properties": {
          "workflowId": { "type": "string" }
        },
        "required": ["workflowId"]
      }
    },
    "agent.session.select": {
      "description": "Switch the active session.",
      "payloadSchema": {
        "type": "object",
        "properties": {
          "sessionId": { "type": "string" }
        },
        "required": ["sessionId"]
      }
    }
  }
}

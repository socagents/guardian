# Phantom — customer install configuration.
#
# Copy this file to `.env` (same directory as docker-compose.yml) and
# fill in the values. Then run `./install.sh`.
#
#   cp .env.example .env
#   chmod 600 .env          # registry token + KEK live here, treat as secret
#   $EDITOR .env
#   ./install.sh
#
# Operator config (model provider, connector instances, webhook
# destinations) is supplied via the UI AFTER first login:
#   - /providers   for the model (Vertex AI / Gemini)
#   - /instances   for connector configs + their secrets
#   - /settings    for non-secret runtime knobs
# The values below are only what's needed at container boot — before
# the operator UI is reachable. UI authentication uses the default
# password seeded from PHANTOM_DEFAULT_ADMIN_PASSWORD below (the
# installer generates a per-install random one); the UI forces you
# to change it at /profile on first login.
#
# ─────────────────────────────────────────────────────────────────────
# v0.3.0+ — IMAGE DIGEST PINNING
#
# This .env contains MANIFEST-MANAGED lines at the bottom (after the
# operator-editable section): one PHANTOM_VERSION line plus 10
# DIGEST_PHANTOM_* lines (5 stack services + 5 per-instance connector
# images). These are written by `phantom-installer` and `install.sh`
# from the release manifest bundled with each release.
#
#   - DO NOT edit the DIGEST_PHANTOM_* lines by hand. Re-running
#     phantom-installer (or the in-app updater) strips and rewrites
#     them as a unit.
#   - To pin to a different release version, download that release's
#     phantom-installer binary or install kit. Each one is sealed to
#     a single version's manifest.
#   - The customer docker-compose.yml references images as
#     `image: ghcr.io/.../svc@${DIGEST_PHANTOM_<SVC>}`. Without these
#     env vars set, docker compose fails loudly with a clear hint
#     pointing back at the installer (rather than silently pulling
#     a wrong image).
#
# See installer/MIGRATION-FROM-V02X.md for the v0.2.x → v0.3.x upgrade
# path; see app/help/architecture#image-pinning for the canonical spec.
# ─────────────────────────────────────────────────────────────────────

# ─── REQUIRED — registry credentials ─────────────────────────────────
# Provided by Kite during onboarding. The token is read-only and
# scoped exclusively to ghcr.io/kite-production/phantom-* images;
# it grants no other access.
PHANTOM_REGISTRY_USER=kite-deploy-bot
PHANTOM_REGISTRY_TOKEN=ghp_REPLACE_WITH_TOKEN_FROM_ONBOARDING

# ─── REQUIRED — internal MCP coordination token ──────────────────────
# Generate a fresh one per install:
#   openssl rand -hex 32
# This token is used only between the Next.js UI and the embedded
# MCP server inside the same container. Not exposed externally.
MCP_TOKEN=

# ─── REQUIRED (v0.3.7+) — secret encryption-at-rest key ─────────────
# AES-256-GCM key the agent uses to encrypt operator-supplied secrets
# (model API keys, XSIAM creds, Vertex SA JSON, etc.) before persisting
# them to disk. Generate a fresh one per install:
#   openssl rand -base64 32
# WARNING: losing this key makes existing stored secrets unrecoverable.
# Back it up alongside your other deployment credentials.
#
# v0.3.7+: this is REQUIRED. The phantom-installer auto-generates one
# on first install, so customer-flow installs never see this empty.
# If you're deploying manually (skipping the installer) and choose
# not to set this, you must also set
# PHANTOM_SECRET_KEK_ALLOW_PLAINTEXT=1 below to acknowledge that
# Vertex SA JSON and other sensitive blobs will land cleartext on
# disk. Pre-v0.3.7 the agent silently fell back to plaintext mode
# with a startup warning; that silent fallback has been removed.
PHANTOM_SECRET_KEK=

# Operator-acknowledged escape hatch — set to "1" only when you're
# knowingly deploying without encryption-at-rest (isolated test
# environment, ephemeral dev container, etc.). Customer installs never
# need this. Leave unset on any production install.
PHANTOM_SECRET_KEK_ALLOW_PLAINTEXT=

# ─── REQUIRED (v0.5.5+) — bootstrap admin password ───────────────────
# The password the agent seeds into SecretStore on first boot for the
# baked admin username. Used ONLY on first boot — the UI then forces
# you to change it at /profile on first login, after which this value
# is never consulted again.
#
# Pre-v0.5.5 this was a hardcoded literal in the phantom-agent image
# (`phantom-admin-CHANGE-ME`). v0.5.5 moves it out of the image so no
# credential is baked anywhere; the installer generates a fresh random
# per-install value here and prints it on the install banner.
#
# Generate (the installer does this automatically — only needed for
# manual installs):
#   openssl rand -base64 24 | tr -d '\n+/=' | cut -c1-24
#
# If you lose this AND haven't yet changed the password at /profile,
# run sudo /opt/phantom/phantom-reset-admin-password from the host to
# set a new one. After you've completed the forced first-login change,
# this value becomes irrelevant — your operator-set password lives in
# SecretStore, encrypted at rest with PHANTOM_SECRET_KEK above.
PHANTOM_DEFAULT_ADMIN_PASSWORD=

# ─── REQUIRED — caldera red-team backend credentials ─────────────────
# Pick any username + a strong password. These are how the agent
# authenticates against caldera for red-team operations. CALDERA_API_KEY
# is also used as the encryption key for caldera's own secret store
# (a separate concept from PHANTOM_SECRET_KEK above — they're
# independent stores).
#
# Generate the API key:
#   openssl rand -hex 16
CALDERA_RED_USER=red
CALDERA_RED_PASSWORD=
CALDERA_API_KEY=

# ─── REQUIRED — xlog bearer token ────────────────────────────────────
# Authenticates calls between phantom-agent and the xlog log-generator
# service. Same value flows to both as XLOG_API_KEY (server) and
# XLOG_API_TOKEN (client) — the compose file aliases them automatically;
# you only need to set this one var.
#
# Generate:
#   openssl rand -hex 32
XLOG_API_KEY=

# ─── OPTIONAL — image version override ───────────────────────────────
# If unset, defaults to whatever version the installer tarball was
# built for. Override only if you need to roll back or pin to a
# specific patch.
# PHANTOM_VERSION=1.2.0

# ─── OPTIONAL — TLS material for caldera ─────────────────────────────
# Caldera runs HTTP-only when these are unset, which is fine if it's
# behind a reverse proxy that terminates TLS. To enable HTTPS directly
# on caldera, paste single-line PEM with literal \n separators (see
# the README's openssl + awk recipe).
# SSL_CERT_PEM=
# SSL_KEY_PEM=

# ─── OPTIONAL — operator pre-config (alternative to in-UI entry) ─────
# v0.4.0+ — most installs leave these blank and use the UI surfaces
# after first login: /providers for the model, /instances for
# connector configs. Pre-populating them here is supported for
# air-gapped or unattended-install scenarios where the operator
# wants to avoid filling the UI by hand. Pre-set values feed the
# in-process MCP-side resolvers, which the chat handler reads.

# XSIAM Cortex PAPI tenant
# CORTEX_MCP_PAPI_URL=
# CORTEX_MCP_PAPI_AUTH_HEADER=
# CORTEX_MCP_PAPI_AUTH_ID=
# PLAYGROUND_ID=

# Webhook destination (when shipping logs to a generic HTTP receiver)
# WEBHOOK_ENDPOINT=
# WEBHOOK_KEY=

# Notification channel webhooks (Slack/Teams/etc.)
# PHANTOM_NOTIFICATION_CHANNEL_SOC=
# PHANTOM_NOTIFICATION_CHANNEL_PURPLE_TEAM=

# Default technology stack (JSON; overridable per-session in the UI)
# TECHNOLOGY_STACK=

# Spark platform gateway (only if integrating with Spark)
# SPARK_PLATFORM_GATEWAY=

# ─── OPTIONAL — log generator tuning ─────────────────────────────────
# WORKERS_NUMBER=4
# LOGGING_DIR=/data/logs
# LOGGING_STORAGE_SIZE=
# LOGGING_TRUNCATE_LIMIT=
# XSIAM_MANDATORY_PARSED_FIELDS=
# XSIAM_OPTIONAL_PARSED_FIELDS=

# ─── MANIFEST-MANAGED (v0.3.0+) — DO NOT EDIT BY HAND ─────────────────
# The phantom-installer (or `install.sh` in the kit-tarball mode)
# appends PHANTOM_VERSION + DIGEST_PHANTOM_* lines below this comment
# from the release manifest. Re-running the installer strips and
# rewrites them as a unit. Manual edits will be overwritten on next
# install/upgrade.
#
# Reference values (filled in by the installer with real digests):
#
#   PHANTOM_VERSION=0.3.0
#   DIGEST_PHANTOM_AGENT=sha256:abc...
#   DIGEST_PHANTOM_XLOG=sha256:def...
#   DIGEST_PHANTOM_CALDERA=sha256:ghi...
#   DIGEST_PHANTOM_UPDATER=sha256:jkl...
#   DIGEST_PHANTOM_BROWSER=sha256:mno...
#   DIGEST_PHANTOM_CONNECTOR_RUNTIME=sha256:pqr...
#   DIGEST_PHANTOM_CONNECTOR_XLOG=sha256:stu...
#   DIGEST_PHANTOM_CONNECTOR_XSIAM=sha256:vwx...
#   DIGEST_PHANTOM_CONNECTOR_CALDERA=sha256:yz0...
#   DIGEST_PHANTOM_CONNECTOR_WEB=sha256:123...

# Files NOT bundled into the phantom-agent docker image.
#
# v0.7.4: introduced when myrobo.webp got re-encoded q=100→q=82 (1.6 MB
# → 172 KB, 9.5× reduction). The original was kept locally for rollback
# at mcp/agent/.image-backups/ — but without a .dockerignore, the
# `COPY mcp/agent/ .` line in the Dockerfile would still bundle it,
# defeating the optimization. This file prevents that.

# Local-only image backups (operator-rollback artifacts)
.image-backups/

# Node modules — installed inside the container, not copied from host
node_modules/

# Next.js build output — rebuilt inside the container
.next/

# Local environment files
.env*.local

# IDE + macOS noise
.DS_Store
.vscode/
.idea/
*.swp
